import 'dart:async';
import 'dart:math';
import 'package:flutter_hooks/flutter_hooks.dart';
import 'package:flutter/material.dart';

class GameScreen extends HookWidget {
  const GameScreen({super.key});

  @override
  Widget build(BuildContext context) {
    const double winDistance = 700.0;

    // Game state
    final boatPositions = useState<List<double>>([0.0, 0.0, 0.0]);
    final winner = useState<String?>(null);
    final isMoving = useState<List<bool>>([false, false, false]);

    // 1. Idle Floating Animation Setup
    final floatController = useAnimationController(
      duration: const Duration(milliseconds: 1500),
    );

    // 2. Rowing Rhythm Animation Setup (Repeats back and forth)
    final rowController = useAnimationController(
      duration: const Duration(milliseconds: 1000),
    );

    useEffect(() {
      floatController.repeat(reverse: true);
      rowController.repeat(reverse: true);

      return null;
    }, []);

    // Float offset for water buoyancy
    final floatOffset = useAnimation(
      Tween<double>(begin: -4.0, end: 4.0).animate(
        CurvedAnimation(parent: floatController, curve: Curves.easeInOutSine),
      ),
    );

    // Rowing offset to slide the rowers back and forth together
    final rowOffset = useAnimation(
      Tween<double>(begin: -3.0, end: 5.0).animate(
        CurvedAnimation(parent: rowController, curve: Curves.easeInOutSine),
      ),
    );

    void moveBoat(int index, double distance) {
      final newPositions = List<double>.from(boatPositions.value);
      newPositions[index] += distance;

      final movingState = List<bool>.from(isMoving.value);
      movingState[index] = true;
      isMoving.value = movingState;

      if (newPositions[index] >= winDistance && winner.value == null) {
        winner.value = index == 0 ? "You Win!" : "AI $index Wins!";
      }

      boatPositions.value = newPositions;

      Future.delayed(const Duration(milliseconds: 250), () {
        final resetState = List<bool>.from(isMoving.value);
        resetState[index] = false;
        isMoving.value = resetState;
      });
    }

    useEffect(() {
      if (winner.value != null) return null;

      final random = Random();
      final timer = Timer.periodic(const Duration(milliseconds: 450), (t) {
        if (winner.value != null) {
          t.cancel();
          return;
        }

        for (int i = 1; i < 3; i++) {
          if (random.nextDouble() < 0.4) {
            moveBoat(i, random.nextInt(35) + 25);
          }
        }
      });

      return timer.cancel;
    }, [winner.value]);

    void resetGame() {
      boatPositions.value = [0.0, 0.0, 0.0];
      isMoving.value = [false, false, false];
      winner.value = null;
      floatController.repeat(reverse: true);
      rowController.repeat(reverse: true);
    }

    return Scaffold(
      appBar: AppBar(
        title: const Center(child: Text("BOAT RACING")),
        actions: [
          IconButton(icon: const Icon(Icons.refresh), onPressed: resetGame),
        ],
      ),
      body: Container(
        color: Colors.cyan,
        child: Stack(
          children: [
            Positioned.fill(
              child: Image.asset(
                'assets/images/phnom_penh_river.png',
                fit: BoxFit.cover,

                colorBlendMode: BlendMode.hardLight,
              ),
            ),
            Row(
              mainAxisAlignment: MainAxisAlignment.center,
              children: [
                for (int i = 0; i < 3; i++)
                  GestureDetector(
                    onTap: () {
                      if (i == 0 && winner.value == null) {
                        moveBoat(0, 50.0);
                      }
                    },
                    child: SizedBox(
                      width: 100,
                      height: double.infinity,
                      // color: Colors.blueGrey.withOpacity(0.8),
                      child: Stack(
                        alignment: Alignment.bottomCenter,
                        children: [
                          // Finish Line
                          Positioned(
                            bottom: winDistance + 140,
                            child: Container(
                              width: 100,
                              height: 8,
                              color: Colors.white38,
                            ),
                          ),

                          // Smooth Moving & Floating Boat Positioner
                          AnimatedPositioned(
                            duration: const Duration(milliseconds: 250),
                            curve: Curves.easeOutQuad,
                            bottom: 40 + boatPositions.value[i] + floatOffset,
                            child: Column(
                              children: [
                                Text(
                                  i == 0 ? "YOU" : "AI $i",
                                  style: const TextStyle(
                                    fontWeight: FontWeight.bold,
                                    color: Colors.white,
                                  ),
                                ),
                                const SizedBox(height: 8),

                                // Dynamic Physics Tilt Rotation
                                AnimatedRotation(
                                  duration: const Duration(milliseconds: 150),
                                  turns: isMoving.value[i] ? -0.02 : 0.0,
                                  child: Container(
                                    width: 50,
                                    height:
                                        120, // Tall boat shell to hold 4 rowers
                                    decoration: BoxDecoration(
                                      color: i == 0
                                          ? Colors.redAccent
                                          : Colors.orangeAccent,
                                      borderRadius: const BorderRadius.only(
                                        topLeft: Radius.circular(25),
                                        topRight: Radius.circular(25),
                                        bottomLeft: Radius.circular(15),
                                        bottomRight: Radius.circular(15),
                                      ),
                                      boxShadow: const [
                                        BoxShadow(
                                          color: Colors.black26,
                                          blurRadius: 4,
                                          offset: Offset(0, 4),
                                        ),
                                      ],
                                    ),
                                    // 3. Rowing Crew Layout
                                    child: Padding(
                                      padding: const EdgeInsets.symmetric(
                                        vertical: 12.0,
                                      ),
                                      child: Column(
                                        mainAxisAlignment:
                                            MainAxisAlignment.spaceEvenly,
                                        children: [
                                          for (
                                            int rower = 0;
                                            rower < 4;
                                            rower++
                                          )
                                            Transform.translate(
                                              // Shifts rowers backward and forward simultaneously
                                              offset: Offset(0, rowOffset),
                                              child: Container(
                                                width: 18,
                                                height: 18,
                                                decoration: BoxDecoration(
                                                  color: Colors.white,
                                                  shape: BoxShape.circle,
                                                  border: Border.all(
                                                    color: Colors
                                                        .blueGrey
                                                        .shade800,
                                                    width: 2,
                                                  ),
                                                  boxShadow: const [
                                                    BoxShadow(
                                                      color: Colors.black12,
                                                      blurRadius: 1,
                                                      offset: Offset(0, 1),
                                                    ),
                                                  ],
                                                ),
                                              ),
                                            ),
                                        ],
                                      ),
                                    ),
                                  ),
                                ),
                              ],
                            ),
                          ),
                        ],
                      ),
                    ),
                  ),
              ],
            ),

            if (winner.value != null)
              Container(
                color: Colors.black87,
                child: Center(
                  child: Column(
                    mainAxisAlignment: MainAxisAlignment.center,
                    children: [
                      Text(
                        winner.value!,
                        style: const TextStyle(
                          color: Colors.white,
                          fontSize: 40,
                          fontWeight: FontWeight.bold,
                        ),
                      ),
                      const SizedBox(height: 20),
                      ElevatedButton(
                        onPressed: resetGame,
                        child: const Text("Play Again"),
                      ),
                    ],
                  ),
                ),
              ),
          ],
        ),
      ),
    );
  }
}

